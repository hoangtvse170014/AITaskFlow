{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "docker",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartThreshold": 3,
    "healthcheckPath": "/actuator/health"
  },
  "env": {
    "SPRING_PROFILES_ACTIVE": "prod"
  }
}
